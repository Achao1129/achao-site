---
interface Props {
  title: string;
  viewAllHref?: string;
}

const { title, viewAllHref } = Astro.props;
---

<div class="rounded-2xl border border-line p-6">
  <div class="mb-5 flex items-center justify-between">
    <h2 class="font-medium text-ink">{title}</h2>
    {
      viewAllHref && (
        <a
          href={viewAllHref}
          class="rounded-full border border-line px-3 py-1 text-xs text-ink-muted transition-colors hover:border-ink hover:text-ink"
        >
          View all
        </a>
      )
    }
  </div>
  <div class="flex flex-col gap-5">
    <slot />
  </div>
</div>
