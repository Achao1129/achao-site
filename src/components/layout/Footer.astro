---
import { SITE, CONTACT_LINKS } from "../../lib/site-config";
const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-8 text-sm text-ink-muted sm:flex-row"
  >
    <p>© {year} {SITE.name}. Built with Astro.</p>
    <div class="flex items-center gap-4">
      {
        CONTACT_LINKS.map((c) => (
          <a href={c.href} class="transition-colors hover:text-ink">
            {c.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
