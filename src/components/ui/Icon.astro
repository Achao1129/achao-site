---
import {
  Sparkles,
  Server,
  Activity,
  BookOpen,
  Hammer,
  Footprints,
  Brain,
  Package,
  Mail,
  Link as LinkIcon,
  Sun,
  Moon,
  Menu,
  X,
  ArrowRight,
  LayoutGrid,
  ExternalLink,
  Rss,
} from "@lucide/astro";

const ICONS = {
  sparkles: Sparkles,
  server: Server,
  activity: Activity,
  "book-open": BookOpen,
  hammer: Hammer,
  footprints: Footprints,
  brain: Brain,
  package: Package,
  mail: Mail,
  link: LinkIcon,
  sun: Sun,
  moon: Moon,
  menu: Menu,
  x: X,
  "arrow-right": ArrowRight,
  "layout-grid": LayoutGrid,
  "external-link": ExternalLink,
  rss: Rss,
} as const;

export type IconName = keyof typeof ICONS | "github";

interface Props {
  name: IconName;
  class?: string;
  strokeWidth?: number;
}

const { name, class: className = "", strokeWidth = 1.75 } = Astro.props;
const Cmp = name === "github" ? null : ICONS[name];
---

{
  Cmp ? (
    <Cmp class={className} stroke-width={strokeWidth} />
  ) : (
    <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
      <path d="M12 .5C5.73.5.5 5.73.5 12.02c0 5.05 3.29 9.33 7.86 10.84.57.1.78-.25.78-.55 0-.27-.01-1.16-.02-2.1-3.2.7-3.87-1.36-3.87-1.36-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.02 11.02 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.64 1.59.24 2.76.12 3.05.74.8 1.19 1.83 1.19 3.08 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.06.78 2.14 0 1.54-.01 2.79-.01 3.17 0 .3.2.66.79.55A11.53 11.53 0 0 0 23.5 12.02C23.5 5.73 18.27.5 12 .5Z" />
    </svg>
  )
}
