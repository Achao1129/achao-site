---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/ui/Icon.astro";

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const statusLabel: Record<string, string> = {
  active: "Active",
  "in-progress": "In progress",
  archived: "Archived",
};
---

<BaseLayout title="Projects" description="正在做和做过的项目。">
  <div class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="font-serif text-4xl text-ink sm:text-5xl">Projects</h1>
    <p class="mt-4 text-lg text-ink-muted">在做和做过的一些东西。</p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        projects.length === 0 ? (
          <p class="text-ink-muted">项目正在整理中。</p>
        ) : (
          projects.map((project) => (
            <div class="rounded-2xl border border-line p-6">
              <div class="flex items-start gap-3">
                <div class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-surface text-ink">
                  <Icon name="package" class="h-5 w-5" />
                </div>
                <div class="min-w-0">
                  <div class="flex items-center gap-2">
                    <h2 class="font-medium text-ink">{project.data.title}</h2>
                    <span class="rounded-full border border-line px-2 py-0.5 text-xs text-ink-muted">
                      {statusLabel[project.data.status]}
                    </span>
                  </div>
                  <p class="mt-2 text-sm text-ink-muted">{project.data.description}</p>

                  <div class="mt-4 flex flex-wrap gap-2">
                    {project.data.tags.map((tag) => (
                      <span class="rounded-full bg-surface px-2.5 py-1 text-xs text-ink-muted">{tag}</span>
                    ))}
                  </div>

                  <div class="mt-4 flex gap-3">
                    {project.data.repo && (
                      <a
                        href={project.data.repo}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 text-sm text-ink-muted hover:text-ink"
                      >
                        <Icon name="github" class="h-4 w-4" />
                        Repo
                      </a>
                    )}
                    {project.data.link && (
                      <a
                        href={project.data.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 text-sm text-ink-muted hover:text-ink"
                      >
                        <Icon name="external-link" class="h-4 w-4" />
                        Visit
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          ))
        )
      }
    </div>
  </div>
</BaseLayout>
