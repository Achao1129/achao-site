---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog" description="AI、代码、基础设施与长期思考的笔记。">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-serif text-4xl text-ink sm:text-5xl">Blog</h1>
    <p class="mt-4 text-lg text-ink-muted">用 Markdown 写的笔记，持续更新。</p>

    <div class="mt-12 flex flex-col gap-10">
      {
        posts.length === 0 ? (
          <p class="text-ink-muted">还没有文章，敬请期待。</p>
        ) : (
          posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="group block border-b border-line pb-8">
              <p class="text-xs text-ink-muted">
                {formatDate(post.data.pubDate)}
                {post.data.tags.length > 0 && ` · ${post.data.tags.join(" · ")}`}
              </p>
              <h2 class="mt-2 text-xl font-medium text-ink group-hover:underline">
                {post.data.title}
              </h2>
              <p class="mt-2 text-ink-muted">{post.data.description}</p>
            </a>
          ))
        )
      }
    </div>
  </div>
</BaseLayout>
