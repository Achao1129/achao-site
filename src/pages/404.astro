---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404" description="页面未找到" noindex>
  <div class="mx-auto flex max-w-3xl flex-col items-center px-6 py-32 text-center">
    <p class="font-serif text-6xl text-ink">404</p>
    <p class="mt-4 text-lg text-ink-muted">这个页面还没有在花园里种下。</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-full bg-ink px-5 py-2.5 text-sm font-medium text-canvas transition-opacity hover:opacity-90"
    >
      返回首页
    </a>
  </div>
</BaseLayout>
